{
  "expo": {
    "name": "RemateVoley",
    "slug": "remate-voley",
    "version": "0.6.0",
    "userInterfaceStyle": "light",
    "orientation": "portrait",
    "scheme": "rematevoley",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#F4F6FB",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.wonderbits.rematevoley",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "RemateVoley usa Bluetooth para conectar con los sensores de muñeca y torso.",
        "NSBluetoothPeripheralUsageDescription": "RemateVoley usa Bluetooth para recibir datos de los sensores.",
        "UIBackgroundModes": [
          "bluetooth-central",
          "bluetooth-central"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "net.wonderbits.rematevoley",
      "permissions": [
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "central"
          ],
          "bluetoothAlwaysPermission": "RemateVoley usa Bluetooth para conectar con los sensores."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "17407b29-b42a-4964-9a4d-53050db9b554"
      }
    }
  }
}
